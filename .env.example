# Solana RPC — use a private/paid endpoint for best performance
# Helius, Triton, QuickNode, Alchemy all give much lower latency than public
RPC_URL=https://api.mainnet-beta.solana.com
RPC_WS_URL=wss://api.mainnet-beta.solana.com

# Your wallet private key (base58) — required for sniper.py, unused by paper_sniper.py
PRIVATE_KEY=YOUR_BASE58_PRIVATE_KEY

# Jito block engine for MEV-protected fast inclusion
JITO_BLOCK_ENGINE_URL=https://mainnet.block-engine.jito.labs.io/api/v1/bundles
USE_JITO=true

# --- Sniper filters ---
MIN_MIGRATION_RATE=0.5       # 0.0–1.0  (e.g. 0.5 = dev must have migrated ≥50% of past tokens)
MIN_TOKENS_LAUNCHED=3        # dev must have launched at least this many tokens before
REQUIRE_SOCIAL=true          # token metadata must have twitter/telegram/website/discord
MIN_MARKET_CAP_SOL=0         # 0 = disabled  (~28 SOL at pump.fun launch)
MAX_MARKET_CAP_SOL=0         # 0 = disabled  (set e.g. 35 to only buy near-launch)
TAKE_PROFIT_MULTIPLE=0       # 0 = disabled; 2.0 = auto-sell paper position when price hits 2× entry

# --- Buy parameters ---
BUY_AMOUNT_SOL=0.1
SLIPPAGE=0.25
PRIORITY_FEE_MICROLAMPORTS=500000
JITO_TIP_SOL=0.003
MAX_CONCURRENT_SNIPES=3

# --- Telegram notifications ---
# Create a bot via @BotFather, then add it to chats and get the chat IDs
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_IDS=123456789,987654321   # comma-separated list of chat IDs

# --- Paper trading ---
PAPER_STARTING_BALANCE_SOL=10.0
SUMMARY_INTERVAL_SECONDS=60
