# Solana RPC (use a private/paid endpoint for best performance)
RPC_URL=https://api.mainnet-beta.solana.com
RPC_WS_URL=wss://api.mainnet-beta.solana.com

# Optional: Helius, Triton, Alchemy, QuickNode recommended for speed
# RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
# RPC_WS_URL=wss://mainnet.helius-rpc.com/?api-key=YOUR_KEY

# Your wallet private key (base58 encoded)
PRIVATE_KEY=YOUR_BASE58_PRIVATE_KEY

# Jito block engine for MEV-protected fast inclusion (optional but recommended)
JITO_BLOCK_ENGINE_URL=https://mainnet.block-engine.jito.labs.io/api/v1/bundles
USE_JITO=true

# --- Sniper Filters ---

# Minimum developer migration rate (0.0 to 1.0, e.g. 0.5 = 50%)
MIN_MIGRATION_RATE=0.5

# Minimum number of tokens the developer must have previously launched
MIN_TOKENS_LAUNCHED=3

# Require at least one social media link in token metadata (twitter/telegram/website)
REQUIRE_SOCIAL=true

# Market cap limits in SOL at time of snipe (0 = disabled)
# Pump.fun launch market cap is ~28 SOL; set MAX to avoid buying already-pumped tokens
MIN_MARKET_CAP_SOL=0
MAX_MARKET_CAP_SOL=0

# --- Buy Parameters ---

# SOL amount to spend per snipe (in SOL)
BUY_AMOUNT_SOL=0.1

# Slippage tolerance (0.0 to 1.0)
SLIPPAGE=0.25

# Priority fee in microlamports (higher = faster inclusion)
PRIORITY_FEE_MICROLAMPORTS=500000

# Jito tip in SOL (added on top of priority fee when USE_JITO=true)
JITO_TIP_SOL=0.003

# Max concurrent snipes in-flight
MAX_CONCURRENT_SNIPES=3
